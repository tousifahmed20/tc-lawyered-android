<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Talk to the hive + the user's chosen LLM provider. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- The floating "read this policy" bubble that hovers over other apps. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Foreground services: the bubble stays alive; screen capture needs its own type. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Post the small "capturing" notification (Android 13+). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".TcLawyeredApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.TcLawyered">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.SettingsActivity"
            android:exported="false"
            android:label="@string/settings_label" />

        <activity
            android:name=".ui.HistoryActivity"
            android:exported="false"
            android:label="@string/history_label" />

        <!-- Share-sheet entry point: "Share -> T&C Lawyered" for text or a link. -->
        <activity
            android:name=".share.ShareReceiverActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:label="@string/share_target_label"
            android:theme="@style/Theme.TcLawyered.Transparent">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <!-- Floating bubble overlay (draw over other apps). -->
        <service
            android:name=".overlay.BubbleService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Persistent on-demand policy reader bubble the user starts explicitly." />
        </service>

        <!-- On-demand screen capture -> on-device OCR. -->
        <service
            android:name=".capture.ScreenCaptureService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />

        <!-- Auto-scroll reader: scrolls the page (via gestures) so the whole policy
             can be read. User-enabled in Accessibility settings; acts only on a bubble tap. -->
        <service
            android:name=".accessibility.ScrollReaderService"
            android:exported="false"
            android:label="@string/accessibility_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_config" />
        </service>

        <!-- Kill switch: the "Stop" action on the capture/bubble notifications. -->
        <receiver
            android:name=".control.StopReceiver"
            android:exported="false" />

    </application>
</manifest>
